    {
      "parameters": {
        "jsCode": "// Pull the merged item (all fields combined into one object)\nconst d = $input.first().json.fields;\n\n// Session comes via Get Session's fields already merged in; but to be safe,\n// reference each source node directly by name:\nconst session = $('Get Session').first().json.fields;\nconst att = $('Get Attendance').first().json.fields;\nconst pre = $('Get Pre-Test').first().json.fields;\nconst post = $('Get Post-Test').first().json.fields;\n\n// Calculations\nconst attendanceRate = att['Total Registered'] > 0\n  ? Math.round((att['Total Present'] / att['Total Registered']) * 1000) / 10\n  : 0;\n\nconst preAvg = pre['Average Score'] || 0;\nconst postAvg = post['Average Score'] || 0;\nconst change = Math.round((postAvg - preAvg) * 100) / 100;\nconst changePct = preAvg > 0 ? Math.round(((postAvg - preAvg) / preAvg) * 1000) / 10 : 0;\nconst knowledgeChange = `${change >= 0 ? '+' : ''}${change} points (${changePct >= 0 ? '+' : ''}${changePct}%)`;\n\nreturn [{\n  json: {\n    trainingTitle: session['Training Title'] || '',\n    trainingDate: session['Date'] || 'Not recorded',\n    trainingLocation: session['Location'] || 'Not recorded',\n    facilitators: session['Facilitator(s)'] || '',\n    topicsDiscussed: session['Topics Discussed'] || '',\n    actionPoints: session['Action Points'] || 'None recorded',\n    comments: session['Comments'] || 'None recorded',\n    recordingLink: session['Recording Link'] || 'Not available',\n    totalRegistered: att['Total Registered'] || 0,\n    totalPresent: att['Total Present'] || 0,\n    male: att['Male'] || 0,\n    female: att['Female'] || 0,\n    attendanceRate: attendanceRate,\n    preTestAvg: preAvg,\n    preTestRespondents: pre['Number of Respondents'] || 0,\n    postTestAvg: postAvg,\n    postTestRespondents: post['Number of Respondents'] || 0,\n    knowledgeChange: knowledgeChange,\n    reportDate: new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }),\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        288
      ],
      "id": "5a177c2f-261d-4179-84aa-0d493f930a98",
      "name": "Calculate Report Values"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Training data for analysis:\n- Training Title: {{ $json.trainingTitle }}\n- Topics Covered: {{ $json.topicsDiscussed }}\n- Total Registered: {{ $json.totalRegistered }}, Total Present: {{ $json.totalPresent }} (Attendance Rate: {{ $json.attendanceRate }}%)\n- Gender split: {{ $json.male }} male, {{ $json.female }} female\n- Pre-Test Average: {{ $json.preTestAvg }} (n={{ $json.preTestRespondents }})\n- Post-Test Average: {{ $json.postTestAvg }} (n={{ $json.postTestRespondents }})\n- Knowledge Change: {{ $json.knowledgeChange }}\n\nSearch the VINAAA-I Strategic Plan for the strategic objectives and priorities most relevant to these training topics, then write the two sections described in your instructions.",
        "options": {
          "systemMessage": "You are a Monitoring, Evaluation and Learning (MEL) analyst at VINAAA-I (Voices in Nigeria Adolescents and Advocacy Initiative), an NGO serving vulnerable communities in Plateau State, Nigeria.\n\nYour task: given training evaluation data, produce TWO sections of a formal training report.\n\nRules:\n1. ALWAYS search the Strategic Plan tool first to find the strategic objectives/pillars relevant to the training topics. Quote or reference the actual strategic language you find.\n2. Be factual. Use ONLY the numbers provided. Never invent data, percentages, or findings.\n3. Small sample sizes (n below 30) must be acknowledged honestly — describe results as \"indicative\" rather than conclusive.\n4. Professional NGO report tone: clear, measured, no hype.\n5. Write in UK English.\n\nOutput EXACTLY this JSON format, nothing else:\n{\n  \"executiveSummary\": \"One paragraph (4-6 sentences): what the training was, who attended, headline knowledge outcome, and one sentence on strategic relevance.\",\n  \"melAnalysis\": \"Two to three paragraphs: (1) interpret the participation and knowledge change data honestly, including limitations; (2) connect the training explicitly to the VINAAA-I strategic objectives you retrieved, naming the specific pillar/objective; (3) one forward-looking implication for programming.\"\n}ou are a helpful assistant"
        }
      },
