    {
      "parameters": {
        "jsCode": "// Get the AI's raw text output\nlet raw = $input.first().json.output;\n\n// Strip markdown fences if the model added them\nraw = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n\n// Parse the JSON\nlet ai;\ntry {\n  ai = JSON.parse(raw);\n} catch (e) {\n  // Fallback: if parsing fails, use raw text for both, flag it\n  ai = {\n    executiveSummary: 'PARSE ERROR - review manually: ' + raw.substring(0, 500),\n    melAnalysis: raw\n  };\n}\n\n// Combine AI sections with all the report data from earlier\nconst reportData = $('Calculate Report Values').first().json;\n\nreturn [{\n  json: {\n    ...reportData,\n    // Force all numerics to strings for Google Docs API\n    totalRegistered: String(reportData.totalRegistered),\n    totalPresent: String(reportData.totalPresent),\n    male: String(reportData.male),\n    female: String(reportData.female),\n    attendanceRate: String(reportData.attendanceRate),\n    preTestAvg: String(reportData.preTestAvg),\n    preTestRespondents: String(reportData.preTestRespondents),\n    postTestAvg: String(reportData.postTestAvg),\n    postTestRespondents: String(reportData.postTestRespondents),\n    executiveSummary: ai.executiveSummary,\n    melAnalysis: ai.melAnalysis,\n  }\n}];"
      },
